@model MVCCinemaProgramme.Models.Hall

@{
    ViewData["Title"] = "Choose a seat";
}

<h1>Choose a seat</h1>

<div>
    <h4>Seats in @Model.Name hall</h4>
    <hr />

<div class="d-flex flex-wrap gap-3">
@foreach (var seat in Model.Seats.OrderBy(s=>s.Number))
    {  
        bool isTaken = ((List<int>)ViewBag.ReservedSeats).Contains(seat.Id);
            string colorClass = isTaken ? "bg-danger" : "bg-success";
            string textColor = "text-white";

            <div class="card @colorClass @textColor text-center" style="width: 80px;">
                <h5 class="card-title">#@seat.Number</h5>
                @if (!isTaken)
                {
                    <a asp-controller="Tickets" asp-action="Create" asp-route-id="@seat.Id" asp-route-programmeId="@ViewBag.ProgrammeId"
                        class="btn btn-light btn-sm mt-1">Reserve</a>
                }
                else
                {
                    <span class="badge bg-secondary">Taken</span>
                }
            </div>
    }
</div>

</div>
<div>
    <a asp-controller="Programmes" asp-action="Details" asp-route-id="@Model.Id" asp-route-programmeId="@ViewBag.ProgrammeId" class=" btn btn-secondary">Cancel and go back</a>
</div>
